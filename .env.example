# LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# API configuration
API_HOST=127.0.0.1
API_PORT=8000
SKILL_SERVER_URL=http://127.0.0.1:8010
MEMORY_DB_PATH=./data/interview_memory.db

# Optional observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=interview-ai-prep
LANGSMITH_TRACING=false

# Optional GUI configuration
GUI_API_URL=http://127.0.0.1:8000/v1/interview/run
GUI_STREAM_API_URL=http://127.0.0.1:8000/v1/interview/stream
